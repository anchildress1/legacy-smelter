{
  "name": "legacy-smelter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "serve": "npm run build && npm run start",
    "test": "vitest",
    "test:run": "vitest run",
    "test:api": "vitest run scripts/server.analyze.integration.test.ts",
    "test:api:emulator": "firebase emulators:exec --only firestore --project demo-legacy-smelter --config firebase.test.json \"vitest run --config vitest.api-emulator.config.ts\"",
    "test:rules": "firebase emulators:exec --only firestore --project demo-legacy-smelter --config firebase.test.json \"vitest run --config vitest.rules.config.ts\"",
    "test:proof": "npm run lint && npm run test:run && npm run test:api:emulator && npm run test:rules",
    "clean": "rm -rf dist",
    "lint": "oxlint && npm run typecheck",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p scripts/tsconfig.json"
  },
  "dependencies": {
    "@google/genai": "^1.49.0",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.7.0",
    "howler": "^2.2.4",
    "image-size": "^2.0.2",
    "lucide-react": "^1.8.0",
    "pixi.js": "^8.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/howler": "^2.2.12",
    "@types/node": "^25.6.0",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "autoprefixer": "^10.4.27",
    "firebase-tools": "^15.14.0",
    "jsdom": "^29.0.2",
    "oxlint": "^1.59.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "@tootallnate/once": "3.0.1"
  },
  "volta": {
    "node": "24.14.1"
  }
}
