# GEMINI_API_KEY: Server-side only. Used by server.js to call the Gemini API.
# NOT prefixed with VITE_ so it is never bundled into the client.
# In Cloud Run, this is injected from Google Secret Manager.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# API rate limiting for POST /api/analyze (IP-based).
# Defaults: 12 requests per 60 seconds, 10000 client IP buckets.
API_RATE_LIMIT_MAX_REQUESTS="12"
API_RATE_LIMIT_WINDOW_MS="60000"
# Optional. Caps the number of distinct client-IP rate buckets to bound
# memory under a high-cardinality flood. Defaults to 10000 if unset.
# API_RATE_LIMIT_MAX_BUCKETS="10000"

# Firebase Config (client-side, bundled into the app via Vite)
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_FIREBASE_AUTH_DOMAIN"
VITE_FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_FIREBASE_STORAGE_BUCKET"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_FIREBASE_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_FIREBASE_APP_ID"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="legacy-smelter"

# Canonical public URL used by both the server (OG metadata) and the
# client (share link generation). Required.
VITE_APP_URL="https://hotfix.anchildress1.dev"

# Server-side admin SDK (server.js, scripts/backfill-evaluated.ts, etc).
# Required вЂ” no fallbacks. Must match the VITE_ values above. The sanction
# judging Cloud Function in `functions/` uses Application Default Credentials
# in its Cloud Run runtime and does not read these variables.
FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
FIREBASE_FIRESTORE_DATABASE_ID="MY_FIRESTORE_DATABASE_ID"

# Admin SDK credential resolution order (first match wins):
#   1. FIREBASE_SERVICE_ACCOUNT_JSON вЂ” inline JSON blob
#   2. GOOGLE_APPLICATION_CREDENTIALS вЂ” absolute path to a key file
#   3. Application Default Credentials (ADC) вЂ” e.g. Cloud Run runtime
# Only set one of these locally. Cloud Run deploys rely on ADC.
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/service-account.json"

# в”Ђв”Ђв”Ђ Local Firebase emulator в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Set these ONLY in `.env.local` when running `make functions` alongside
# `make dev` + `make server`. With the emulator running on the pinned ports
# from firebase.json (firestore:9180, auth:9099, functions:5001), the
# following wiring routes every local write to the emulator вЂ” which fires
# the local `onIncidentCreated` trigger вЂ” and leaves production untouched:
#
#   1. VITE_USE_FIREBASE_EMULATOR=true
#      в†’ `src/firebase.ts` calls `connectFirestoreEmulator` + `connectAuthEmulator`
#        so the browser SDK talks to the local emulator instead of prod.
#
#   2. FIRESTORE_EMULATOR_HOST=127.0.0.1:9180
#      в†’ `shared/admin-init.js` logs the emulator destination at boot, and
#        the firebase-admin SDK auto-routes every server-side Firestore
#        read/write (server.js, scripts/*) through the emulator.
#
# If either is missing, writes from that side silently go to the production
# `legacy-smelter` database and fire the production Cloud Function вЂ” which
# is why "zero logs in the emulator console" is usually a mis-set env var.
# VITE_USE_FIREBASE_EMULATOR="true"
# FIRESTORE_EMULATOR_HOST="127.0.0.1:9180"
