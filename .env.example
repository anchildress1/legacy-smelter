# GEMINI_API_KEY: Required for Gemini AI API calls.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Firebase Config
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_FIREBASE_AUTH_DOMAIN"
VITE_FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_FIREBASE_STORAGE_BUCKET"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_FIREBASE_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_FIREBASE_APP_ID"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="MY_FIREBASE_FIRESTORE_DATABASE_ID"

# VITE_APP_URL: Canonical public URL used by both the server (OG metadata) and the
# client (share link generation). If omitted, both fall back to
# https://hotfix.anchildress1.dev.
VITE_APP_URL="https://hotfix.anchildress1.dev"

# Cron script (audience-favorite): uses VITE_ vars as fallback, but these
# non-prefixed vars are preferred for server-side scripts.
# GEMINI_API_KEY="MY_GEMINI_API_KEY"
# FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
# FIREBASE_FIRESTORE_DATABASE_ID="MY_FIRESTORE_DATABASE_ID"
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
