# GEMINI_API_KEY: Required for Gemini AI API calls.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Firebase Config
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_FIREBASE_AUTH_DOMAIN"
VITE_FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_FIREBASE_STORAGE_BUCKET"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_FIREBASE_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_FIREBASE_APP_ID"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="MY_FIREBASE_FIRESTORE_DATABASE_ID"

# APP_URL: Production URL — used by server.js when constructing canonical OG URLs.
APP_URL="MY_APP_URL"

# VITE_APP_URL: Same URL, baked into the client bundle for share link generation.
# If omitted, the client falls back to window.location.origin (correct in most deploys).
VITE_APP_URL="MY_APP_URL"
