# GEMINI_API_KEY: Server-side only. Used by server.js to call the Gemini API.
# NOT prefixed with VITE_ so it is never bundled into the client.
# In Cloud Run, this is injected from Google Secret Manager.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# API rate limiting for POST /api/analyze (IP-based).
# Defaults: 12 requests per 60 seconds.
API_RATE_LIMIT_MAX_REQUESTS="12"
API_RATE_LIMIT_WINDOW_MS="60000"

# Firebase Config (client-side, bundled into the app via Vite)
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_FIREBASE_AUTH_DOMAIN"
VITE_FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_FIREBASE_STORAGE_BUCKET"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_FIREBASE_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_FIREBASE_APP_ID"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="legacy-smelter"

# Canonical public URL used by both the server (OG metadata) and the
# client (share link generation). Required.
VITE_APP_URL="https://hotfix.anchildress1.dev"

# Server-side scripts (sanction-incidents.ts). Required — no fallbacks.
FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
FIREBASE_FIRESTORE_DATABASE_ID="MY_FIRESTORE_DATABASE_ID"
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
