rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // incident_logs:
    //   - Creates happen server-side via firebase-admin (rules bypassed).
    //   - Reads are public.
    //   - Client updates are limited to single-field counter increments
    //     (breach_count, escalation_count). Escalation additionally requires
    //     a matching write to the escalations/{uid} subcollection via a
    //     client-side transaction.
    //   - Deletes are disallowed for clients.
    match /incident_logs/{logId} {
      function escalationDocPath(uid) {
        return /databases/$(database)/documents/incident_logs/$(logId)/escalations/$(uid);
      }

      // Duplicates src/types.ts::computeImpact and shared/impactScore formulas.
      // Firestore rules cannot import TypeScript, so this MUST be kept in sync
      // with the weights (sanction=5, escalation=3, breach=2).
      function impactScore(data) {
        return (data.sanction_count * 5) + (data.escalation_count * 3) + (data.breach_count * 2);
      }

      // Defensive getters: legacy docs written before the impact_score
      // backfill may be missing the field. `get(field, default)` returns the
      // default on missing/null so arithmetic doesn't short-circuit the rule
      // to false on otherwise-valid clients. The final `impactScore(...)`
      // equality check still enforces that the post-write value matches the
      // weighted-sum invariant.
      function isBreachIncrement() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['breach_count', 'impact_score']) &&
               request.resource.data.breach_count == resource.data.get('breach_count', 0) + 1 &&
               request.resource.data.impact_score == resource.data.get('impact_score', 0) + 2 &&
               request.resource.data.impact_score == impactScore(request.resource.data);
      }

      function isEscalationIncrement() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['escalation_count', 'impact_score']) &&
               request.resource.data.escalation_count == resource.data.get('escalation_count', 0) + 1 &&
               request.resource.data.impact_score == resource.data.get('impact_score', 0) + 3 &&
               request.resource.data.impact_score == impactScore(request.resource.data) &&
               !exists(escalationDocPath(request.auth.uid)) &&
               existsAfter(escalationDocPath(request.auth.uid));
      }

      function isEscalationDecrement() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['escalation_count', 'impact_score']) &&
               resource.data.get('escalation_count', 0) > 0 &&
               request.resource.data.escalation_count == resource.data.get('escalation_count', 0) - 1 &&
               request.resource.data.impact_score == resource.data.get('impact_score', 0) - 3 &&
               request.resource.data.impact_score == impactScore(request.resource.data) &&
               exists(escalationDocPath(request.auth.uid)) &&
               !existsAfter(escalationDocPath(request.auth.uid));
      }

      allow read: if true;
      allow create: if false;
      allow delete: if false;
      allow update: if request.auth != null &&
                       (
                         isBreachIncrement() ||
                         isEscalationIncrement() ||
                         isEscalationDecrement()
                       );

      // Per-user escalation tracking: one doc per user per incident
      match /escalations/{escId} {
        function parentLogPath() {
          return /databases/$(database)/documents/incident_logs/$(logId);
        }

        function escDocPath() {
          return /databases/$(database)/documents/incident_logs/$(logId)/escalations/$(escId);
        }

        function parentEscalationIncremented() {
          return exists(parentLogPath()) &&
                 existsAfter(parentLogPath()) &&
                 getAfter(parentLogPath()).data.escalation_count == get(parentLogPath()).data.escalation_count + 1;
        }

        function parentEscalationDecremented() {
          return exists(parentLogPath()) &&
                 existsAfter(parentLogPath()) &&
                 get(parentLogPath()).data.escalation_count > 0 &&
                 getAfter(parentLogPath()).data.escalation_count == get(parentLogPath()).data.escalation_count - 1;
        }

        allow read: if request.auth != null && escId == request.auth.uid;
        allow create: if request.auth != null && escId == request.auth.uid &&
                         request.resource.data.keys().hasOnly(['uid', 'timestamp']) &&
                         request.resource.data.uid is string &&
                         request.resource.data.uid == request.auth.uid &&
                         request.resource.data.timestamp is timestamp &&
                         !exists(escDocPath()) &&
                         existsAfter(escDocPath()) &&
                         parentEscalationIncremented();
        allow delete: if request.auth != null && escId == request.auth.uid &&
                        exists(escDocPath()) &&
                        !existsAfter(escDocPath()) &&
                        parentEscalationDecremented();
      }
    }

    // global_stats:
    //   - Reads are public.
    //   - Writes are server-side only (admin SDK bypasses rules).
    match /global_stats/main {
      allow read: if true;
      allow write: if false;
    }

    // Deny-by-default for everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
